<ui:FluentWindow x:Class="AntivirusUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Virus Removal Tool" Height="550" Width="880"
        MinWidth="800" MinHeight="500"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Virus Removal Tool" />

        <Grid Grid.Row="1" Margin="30,10,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,30" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <ui:SymbolIcon Symbol="Shield24" FontSize="36" Foreground="#FFFFFF" Margin="0,0,10,0"/>
                    <TextBlock Text="Virus Removal Tool" Foreground="#FFFFFF" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="ESCÁNER DE MALWARE Y DESTRUCTOR ASSEMBLY" Foreground="#00FF41" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#44000000" CornerRadius="8" Padding="20" Margin="0,0,0,25"
                    BorderBrush="#22FFFFFF" BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ui:TextBox Grid.Column="0" x:Name="txtRuta" Height="40" FontSize="14" IsReadOnly="True" PlaceholderText="Seleccione una ruta..." Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <ui:Button Grid.Column="1" x:Name="btnSeleccionar" Height="40" Padding="15,0" Click="BtnSeleccionar_Click" Margin="0,0,10,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Elegir Carpeta" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Grid.Column="2" x:Name="btnEscanear" Height="40" Padding="15,0" Click="BtnEscanear_Click" Margin="0,0,10,0" VerticalAlignment="Center" Appearance="Primary">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Search24" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Escanear" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Grid.Column="3" x:Name="btnDestruir" Height="40" Padding="15,0" Click="BtnDestruir_Click" VerticalAlignment="Center" Appearance="Danger">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Destruir Archivo" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#88000000" CornerRadius="8" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="15">
                <ListBox x:Name="lstResultados" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,3"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#00FF41" FontFamily="Consolas" FontSize="14" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>