<Window x:Class="AntivirusUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Motor Antivirus - Lenguaje de Máquina" Height="450" Width="700" Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ESCANER DE MALWARE AVANZADO" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Grid.Row="0" HorizontalAlignment="Center"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBox x:Name="txtRuta" Width="400" Height="30" Padding="5" VerticalContentAlignment="Center" IsReadOnly="True" Background="#333" Foreground="White" BorderBrush="#555"/>
            <Button x:Name="btnSeleccionar" Content="Elegir Carpeta" Width="100" Height="30" Margin="10,0,0,0" Background="#007ACC" Foreground="White" BorderThickness="0" Click="BtnSeleccionar_Click"/>
            <Button x:Name="btnEscanear" Content="ESCANEAR" Width="100" Height="30" Margin="10,0,0,0" Background="#E51400" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnEscanear_Click"/>
        </StackPanel>

        <ListBox x:Name="lstResultados" Grid.Row="2" Background="#0C0C0C" Foreground="#00FF00" FontFamily="Consolas" Padding="10" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
    </Grid>
</Window>